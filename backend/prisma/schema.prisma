// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma_ahbb"
}

datasource db {
  provider = "postgresql"
}

model td_usuario_ahbb {
  id_usuario_ahbb                 Int      @id @default(autoincrement())
  cedula_ahbb                     String   @unique @db.VarChar(50)
  nombre_ahbb                     String   @db.VarChar(100)
  apellido_ahbb                   String   @db.VarChar(100)
  correo_ahbb                     String   @unique @db.VarChar(150)
  contrasena_ahbb                 String   @db.VarChar(255)
  rol_ahbb                        String?  @default("ALUMNO") @db.VarChar(20)
  firmaDigital_ahbb               String?  @db.Text
  estadoCuenta_ahbb               String   @default("PENDIENTE_APROBACION") @db.VarChar(40)
  requiereCambioContrasena_ahbb   Boolean  @default(false)
  referenciaPagoMovil_ahbb        String?  @db.VarChar(120)
  aprobadoPorUsuarioId_ahbb       Int?
  creadoEn_ahbb                   DateTime? @default(now()) @db.Timestamp(6)
  actualizadoEn_ahbb DateTime? @default(now()) @db.Timestamp(6)

  // Relaciones
  cursos                    td_curso_ahbb[]
  inscripciones             td_inscripcion_ahbb[]
  auditoriasAprobadas_ahbb  td_auditoria_aprobacion_ahbb[] @relation("AprobadorAuditoria")
  auditoriasUsuario_ahbb    td_auditoria_aprobacion_ahbb[] @relation("UsuarioAuditado")

  // Relaciones Tienda (E-Commerce)
  carrito_ahbb              td_carrito_ahbb[]
  facturas_ahbb             td_factura_ahbb[]
  favoritos_ahbb            td_favorito_ahbb[]

  // Relaciones Módulo Académico (Carreras y Pensums)
  inscripcionesMaterias_cjgp td_inscripcion_materia_cjgp[]
  materiasDictadas_cjgp      td_materia_cjgp[] @relation("ProfesorMateria")
  calificacionesCargadas_jc  td_calificacion_jc[]
  actasGeneradas_jc          td_acta_jc[]

  // Relaciones Módulo Multimedia y Videollamadas (_jf)
  progresosMultimedia_jf     td_progreso_lecciones_jf[]
  intentosMultimedia_jf      td_intento_evaluacion_jf[]
  salasCreadas_jf            td_salas_videollamadas_jf[]
}

model td_curso_ahbb {
  id_curso_ahbb                Int      @id @default(autoincrement())
  nombre_ahbb                  String   @db.VarChar(200)
  tematica_ahbb                String   @db.VarChar(200)
  descripcion_ahbb             String?  @db.Text
  diasDefinidos_ahbb           Int
  horasDefinidas_ahbb          Int
  fechaInicio_ahbb             DateTime? @db.Timestamp(6)
  fechaFin_ahbb                DateTime? @db.Timestamp(6)
  fechaDuracion_ahbb           DateTime? @db.Timestamp(6)
  topeEstudiantes_ahbb         Int?     @default(5)
  temarioTexto_ahbb            String?  @db.Text
  imagenBasePdf_ahbb           String?  @db.Text
  imagenBloqueada_ahbb         Boolean? @default(false)
  isPublished_ahbb             Boolean  @default(false)
  estadoAprobacion_ahbb        String   @default("ACTIVO") @db.VarChar(20)
  motivoRechazo_ahbb           String?  @db.Text
  mensajeCorreccion_ahbb       String?  @db.Text
  id_usuario_curso_ahbb        Int
  id_curso_curso_ahbb          Int?
  creadoEn_ahbb                DateTime? @default(now()) @db.Timestamp(6)
  actualizadoEn_ahbb           DateTime? @default(now()) @db.Timestamp(6)

  // Relaciones
  profesor      td_usuario_ahbb        @relation(fields: [id_usuario_curso_ahbb], references: [id_usuario_ahbb])
  prelacion     td_curso_ahbb?         @relation("Prelacion", fields: [id_curso_curso_ahbb], references: [id_curso_ahbb])
  prelaciones   td_curso_ahbb[]        @relation("Prelacion")
  horarios      td_horario_ahbb[]
  inscripciones td_inscripcion_ahbb[]
  sesiones      td_sesion_curso_ahbb[]

  // Relaciones Módulo Multimedia y Videollamadas (_jf)
  bloques_jf    td_bloques_jf[]
  salas_jf      td_salas_videollamadas_jf[]
}

model td_sesion_curso_ahbb {
  id_sesion_ahbb        Int      @id @default(autoincrement())
  nroSesion_ahbb        Int
  fechaSesion_ahbb      DateTime @db.Date
  horaInicio_ahbb       String   @db.VarChar(10)
  horaFin_ahbb          String   @db.VarChar(10)
  horasDuracion_ahbb    Decimal  @db.Decimal(4, 2)
  diaSemana_ahbb        String   @db.VarChar(20)
  id_curso_sesion_ahbb  Int

  // Relaciones
  curso                 td_curso_ahbb @relation(fields: [id_curso_sesion_ahbb], references: [id_curso_ahbb], onDelete: Cascade)
}


model td_horario_ahbb {
  id_horario_ahbb       Int      @id @default(autoincrement())
  diaSemana_ahbb        String   @db.VarChar(20)
  horaInicio_ahbb       String   @db.VarChar(10)
  horaFin_ahbb          String   @db.VarChar(10)
  id_curso_horario_ahbb  Int

  // Relaciones
  curso                 td_curso_ahbb @relation(fields: [id_curso_horario_ahbb], references: [id_curso_ahbb], onDelete: Cascade)
}

model td_inscripcion_ahbb {
  id_inscripcion_ahbb         Int      @id @default(autoincrement())
  estatus_ahbb                String?  @default("INSCRITO") @db.VarChar(50)
  intento_ahbb                Int      @default(1)
  id_usuario_inscripcion_ahbb Int
  id_curso_inscripcion_ahbb   Int
  creadoEn_ahbb               DateTime? @default(now()) @db.Timestamp(6)
  actualizadoEn_ahbb           DateTime? @default(now()) @db.Timestamp(6)

  // Relaciones
  alumno                      td_usuario_ahbb @relation(fields: [id_usuario_inscripcion_ahbb], references: [id_usuario_ahbb], onDelete: Cascade)
  curso                       td_curso_ahbb   @relation(fields: [id_curso_inscripcion_ahbb], references: [id_curso_ahbb], onDelete: Cascade)
  certificado                 td_certificado_ahbb?

  // Relaciones Módulo Multimedia y Videollamadas (_jf)
  progresosMultimedia_jf      td_progreso_lecciones_jf[]
  intentosMultimedia_jf       td_intento_evaluacion_jf[]

  // @@unique removed: allows re-enrollment when student was REPROBADO
  @@index([id_usuario_inscripcion_ahbb, id_curso_inscripcion_ahbb])
}

model td_certificado_ahbb {
  id_certificado_ahbb             Int      @id @default(autoincrement())
  codigoQrUrl_ahbb                String   @db.Text
  id_inscripcion_certificado_ahbb Int      @unique
  creadoEn_ahbb                   DateTime? @default(now()) @db.Timestamp(6)

  // Relaciones
  inscripcion                     td_inscripcion_ahbb @relation(fields: [id_inscripcion_certificado_ahbb], references: [id_inscripcion_ahbb], onDelete: Cascade)
}

model td_configuracionglobal_ahbb {
  id_configuracionglobal_ahbb   Int      @id @default(autoincrement())
  imagenCertificadoGeneral_ahbb String?  @db.Text
}

model td_auditoria_aprobacion_ahbb {
  id_auditoria_aprobacion_ahbb Int      @id @default(autoincrement())
  tipoOperacion_ahbb           String   @db.VarChar(50)
  referenciaOperacion_ahbb     String   @db.VarChar(120)
  observacion_ahbb             String?  @db.Text
  id_usuario_auditado_ahbb     Int
  id_aprobador_ahbb            Int
  creadoEn_ahbb                DateTime @default(now()) @db.Timestamp(6)

  usuarioAuditado_ahbb         td_usuario_ahbb @relation("UsuarioAuditado", fields: [id_usuario_auditado_ahbb], references: [id_usuario_ahbb])
  aprobador_ahbb               td_usuario_ahbb @relation("AprobadorAuditoria", fields: [id_aprobador_ahbb], references: [id_usuario_ahbb])
}

// ══════════════════════════════════════════════════════════════
// MÓDULO TIENDA (E-COMMERCE) — ACADEMIA H&B
// ══════════════════════════════════════════════════════════════

model td_producto_ahbb {
  id_producto_ahbb       Int      @id @default(autoincrement())
  nombre_ahbb            String   @db.VarChar(150)
  descripcion_ahbb       String?  @db.Text
  precio_ahbb            Decimal  @db.Decimal(10, 2)
  stock_ahbb             Int      @default(0)
  categoria_ahbb         String   @db.VarChar(50)
  imagen_ahbb            String?  @db.Text
  estado_producto_ahbb   String   @default("activo") @db.VarChar(20)
  creadoEn_ahbb          DateTime? @default(now()) @db.Timestamp(6)
  actualizadoEn_ahbb     DateTime? @default(now()) @db.Timestamp(6)

  // Relaciones
  itemsCarrito_ahbb      td_carrito_ahbb[]
  detallesFactura_ahbb   td_detalle_factura_ahbb[]
  favoritos_ahbb         td_favorito_ahbb[]
}

model td_carrito_ahbb {
  id_carrito_ahbb          Int      @id @default(autoincrement())
  cantidad_ahbb            Int      @default(1)
  fechaAgregado_ahbb       DateTime? @default(now()) @db.Timestamp(6)
  id_usuario_carrito_ahbb  Int
  id_producto_carrito_ahbb Int

  // Relaciones
  usuario_ahbb   td_usuario_ahbb  @relation(fields: [id_usuario_carrito_ahbb], references: [id_usuario_ahbb], onDelete: Cascade)
  producto_ahbb  td_producto_ahbb @relation(fields: [id_producto_carrito_ahbb], references: [id_producto_ahbb], onDelete: Cascade)

  @@unique([id_usuario_carrito_ahbb, id_producto_carrito_ahbb])
}

model td_factura_ahbb {
  id_factura_ahbb           Int      @id @default(autoincrement())
  nroReferenciaPago_ahbb    String   @db.VarChar(50)
  fechaFactura_ahbb         DateTime? @default(now()) @db.Timestamp(6)
  total_ahbb                Decimal  @db.Decimal(10, 2)
  estadoFactura_ahbb        String   @default("pendiente") @db.VarChar(20)
  id_usuario_factura_ahbb   Int

  // Relaciones
  usuario_ahbb   td_usuario_ahbb          @relation(fields: [id_usuario_factura_ahbb], references: [id_usuario_ahbb], onDelete: Cascade)
  detalles_ahbb  td_detalle_factura_ahbb[]
  reportes_ahbb  td_reportes_facturas_ahbb[]
}

model td_reportes_facturas_ahbb {
  id_reporte_ahbb           Int      @id @default(autoincrement())
  id_factura_reporte_ahbb   Int
  qr_base64_ahbb            String   @db.Text
  creadoEn_ahbb             DateTime @default(now()) @db.Timestamp(6)

  // Relaciones
  factura_ahbb   td_factura_ahbb   @relation(fields: [id_factura_reporte_ahbb], references: [id_factura_ahbb], onDelete: Cascade)
}

model td_detalle_factura_ahbb {
  id_detalle_factura_ahbb     Int     @id @default(autoincrement())
  cantidad_ahbb               Int
  precioUnitario_ahbb         Decimal @db.Decimal(10, 2)
  id_factura_detalle_ahbb     Int
  id_producto_detalle_ahbb    Int

  // Relaciones
  factura_ahbb   td_factura_ahbb   @relation(fields: [id_factura_detalle_ahbb], references: [id_factura_ahbb], onDelete: Cascade)
  producto_ahbb  td_producto_ahbb  @relation(fields: [id_producto_detalle_ahbb], references: [id_producto_ahbb])
}

model td_favorito_ahbb {
  id_favorito_ahbb           Int      @id @default(autoincrement())
  fechaAgregado_ahbb         DateTime? @default(now()) @db.Timestamp(6)
  id_usuario_favorito_ahbb   Int
  id_producto_favorito_ahbb  Int

  // Relaciones
  usuario_ahbb   td_usuario_ahbb  @relation(fields: [id_usuario_favorito_ahbb], references: [id_usuario_ahbb], onDelete: Cascade)
  producto_ahbb  td_producto_ahbb @relation(fields: [id_producto_favorito_ahbb], references: [id_producto_ahbb], onDelete: Cascade)

  @@unique([id_usuario_favorito_ahbb, id_producto_favorito_ahbb])
}

// ══════════════════════════════════════════════════════════════
// MÓDULO ACADÉMICO: CARRERAS, PENSUMS E INSCRIPCIÓN (_cjgp)
// Trabajo grupal: Coffi, Jorge, Guillermo y Padrino
// ══════════════════════════════════════════════════════════════

model td_carrera_cjgp {
  id_carrera_cjgp       Int      @id @default(autoincrement())
  codigo_cjgp           String   @unique @db.VarChar(20)
  nombre_cjgp           String   @db.VarChar(200)
  descripcion_cjgp      String?  @db.Text
  // Régimen del período académico: SEMESTRAL (2 bloques/año) o TRIMESTRAL (3 bloques/año)
  regimen_cjgp          String   @default("SEMESTRAL") @db.VarChar(20)
  duracionAnios_cjgp    Int
  // Límite estricto de créditos que un alumno puede inscribir por período (Épica 2)
  limiteCreditos_cjgp   Int      @default(21)
  estado_cjgp           String   @default("ACTIVA") @db.VarChar(20)
  creadoEn_cjgp         DateTime? @default(now()) @db.Timestamp(6)
  actualizadoEn_cjgp    DateTime? @default(now()) @db.Timestamp(6)

  // Relaciones
  materias_cjgp         td_materia_cjgp[]
  planesEvaluacion_jc   td_plan_evaluacion_jc[]
}

model td_materia_cjgp {
  id_materia_cjgp          Int     @id @default(autoincrement())
  codigo_cjgp              String  @db.VarChar(20)
  nombre_cjgp              String  @db.VarChar(200)
  creditos_cjgp            Int
  // Bloque (semestre o trimestre) del pensum al que pertenece la materia
  nroBloque_cjgp           Int
  id_carrera_materia_cjgp  Int
  // Profesor asignado por el administrador para dictar la materia
  id_profesor_materia_cjgp Int?
  creadoEn_cjgp            DateTime? @default(now()) @db.Timestamp(6)

  // Relaciones
  carrera_cjgp        td_carrera_cjgp @relation(fields: [id_carrera_materia_cjgp], references: [id_carrera_cjgp], onDelete: Cascade)
  profesor_cjgp       td_usuario_ahbb? @relation("ProfesorMateria", fields: [id_profesor_materia_cjgp], references: [id_usuario_ahbb])
  prelaciones_cjgp    td_prelacion_cjgp[] @relation("MateriaConRequisito")
  esRequisitoDe_cjgp  td_prelacion_cjgp[] @relation("MateriaRequisito")
  inscripciones_cjgp  td_inscripcion_materia_cjgp[]
  actas_jc            td_acta_jc[]

  // Un código de materia no puede repetirse dentro de la misma carrera
  @@unique([id_carrera_materia_cjgp, codigo_cjgp])
}

// Prelaciones: "Base de Datos II" requiere "Base de Datos I" (Épica 1 y 2)
model td_prelacion_cjgp {
  id_prelacion_cjgp          Int @id @default(autoincrement())
  id_materia_cjgp            Int
  id_materia_requisito_cjgp  Int

  // Relaciones
  materia_cjgp    td_materia_cjgp @relation("MateriaConRequisito", fields: [id_materia_cjgp], references: [id_materia_cjgp], onDelete: Cascade)
  requisito_cjgp  td_materia_cjgp @relation("MateriaRequisito", fields: [id_materia_requisito_cjgp], references: [id_materia_cjgp], onDelete: Cascade)

  @@unique([id_materia_cjgp, id_materia_requisito_cjgp])
}

model td_periodo_academico_cjgp {
  id_periodo_cjgp   Int      @id @default(autoincrement())
  nombre_cjgp       String   @unique @db.VarChar(30)
  fechaInicio_cjgp  DateTime @db.Date
  fechaFin_cjgp     DateTime @db.Date
  // Solo un período puede estar activo a la vez (lo garantiza el servicio)
  activo_cjgp       Boolean  @default(false)
  creadoEn_cjgp     DateTime? @default(now()) @db.Timestamp(6)

  // Relaciones
  inscripciones_cjgp    td_inscripcion_materia_cjgp[]
  planesEvaluacion_jc   td_plan_evaluacion_jc[]
  actas_jc              td_acta_jc[]
}

// Historial académico del alumno por materia y período (Épica 2 y 3)
model td_inscripcion_materia_cjgp {
  id_inscripcion_materia_cjgp Int      @id @default(autoincrement())
  // INSCRITO | APROBADO | REPROBADO | RETIRADO
  estatus_cjgp                String   @default("INSCRITO") @db.VarChar(20)
  notaFinal_cjgp              Decimal? @db.Decimal(5, 2)
  id_usuario_im_cjgp          Int
  id_materia_im_cjgp          Int
  id_periodo_im_cjgp          Int
  creadoEn_cjgp               DateTime? @default(now()) @db.Timestamp(6)
  actualizadoEn_cjgp          DateTime? @default(now()) @db.Timestamp(6)

  // Relaciones
  alumno_cjgp   td_usuario_ahbb           @relation(fields: [id_usuario_im_cjgp], references: [id_usuario_ahbb], onDelete: Cascade)
  materia_cjgp  td_materia_cjgp           @relation(fields: [id_materia_im_cjgp], references: [id_materia_cjgp], onDelete: Cascade)
  periodo_cjgp  td_periodo_academico_cjgp @relation(fields: [id_periodo_im_cjgp], references: [id_periodo_cjgp], onDelete: Cascade)
  calificaciones_jc td_calificacion_jc[]

  // Un alumno solo puede cursar una vez la misma materia dentro de un período
  @@unique([id_usuario_im_cjgp, id_materia_im_cjgp, id_periodo_im_cjgp])
  @@index([id_usuario_im_cjgp, id_periodo_im_cjgp])
}

// ══════════════════════════════════════════════════════════════
// MÓDULO CONTROL DE ESTUDIOS (_jc)
// Plan de evaluación parametrizado, carga de notas y actas
// Enfoque: Desarrollo Basado en Metadatos — el código NO conoce
// cuántas evaluaciones existen; todo se lee de esta configuración.
// ══════════════════════════════════════════════════════════════

model td_plan_evaluacion_jc {
  id_plan_jc          Int      @id @default(autoincrement())
  nombre_jc           String   @db.VarChar(150)
  // Escala de la nota (ej. 20 puntos, 100 puntos) y mínima aprobatoria
  notaMaxima_jc       Decimal  @default(20) @db.Decimal(5, 2)
  notaAprobatoria_jc  Decimal  @default(10) @db.Decimal(5, 2)
  // BORRADOR | PUBLICADO — solo los publicados rigen la carga de notas
  estado_jc           String   @default("BORRADOR") @db.VarChar(20)
  id_periodo_plan_jc  Int
  // Si es null, el plan es institucional (aplica a todas las carreras del período)
  id_carrera_plan_jc  Int?
  creadoEn_jc         DateTime? @default(now()) @db.Timestamp(6)
  actualizadoEn_jc    DateTime? @default(now()) @db.Timestamp(6)

  // Relaciones
  periodo_jc  td_periodo_academico_cjgp @relation(fields: [id_periodo_plan_jc], references: [id_periodo_cjgp], onDelete: Cascade)
  carrera_jc  td_carrera_cjgp?          @relation(fields: [id_carrera_plan_jc], references: [id_carrera_cjgp], onDelete: Cascade)
  items_jc    td_item_evaluacion_jc[]

  // Un solo plan por período/carrera para garantizar uniformidad en las actas
  @@unique([id_periodo_plan_jc, id_carrera_plan_jc])
}

// Cada hito de evaluación configurable: "Corte 1", "Módulo A", "Reparación"...
model td_item_evaluacion_jc {
  id_item_jc      Int     @id @default(autoincrement())
  nombre_jc       String  @db.VarChar(100)
  orden_jc        Int
  // Peso porcentual del ítem sobre la definitiva (los de recuperación no suman)
  peso_jc         Decimal @db.Decimal(5, 2)
  // true = condición especial tipo "Reparación": sustituye la definitiva reprobada
  esRecuperacion_jc Boolean @default(false)
  id_plan_item_jc Int

  // Relaciones
  plan_jc          td_plan_evaluacion_jc @relation(fields: [id_plan_item_jc], references: [id_plan_jc], onDelete: Cascade)
  calificaciones_jc td_calificacion_jc[]

  @@unique([id_plan_item_jc, orden_jc])
}

// Nota obtenida por un alumno en un ítem del plan de evaluación
model td_calificacion_jc {
  id_calificacion_jc            Int      @id @default(autoincrement())
  valor_jc                      Decimal  @db.Decimal(5, 2)
  id_inscripcion_materia_cal_jc Int
  id_item_cal_jc                Int
  cargadoPorUsuarioId_jc        Int?
  creadoEn_jc                   DateTime? @default(now()) @db.Timestamp(6)
  actualizadoEn_jc              DateTime? @default(now()) @db.Timestamp(6)

  // Relaciones
  inscripcionMateria_jc td_inscripcion_materia_cjgp @relation(fields: [id_inscripcion_materia_cal_jc], references: [id_inscripcion_materia_cjgp], onDelete: Cascade)
  item_jc               td_item_evaluacion_jc       @relation(fields: [id_item_cal_jc], references: [id_item_jc], onDelete: Cascade)
  cargadoPor_jc         td_usuario_ahbb?            @relation(fields: [cargadoPorUsuarioId_jc], references: [id_usuario_ahbb])

  // Una sola nota por alumno-inscripción e ítem de evaluación
  @@unique([id_inscripcion_materia_cal_jc, id_item_cal_jc])
}

// Registro de actas generadas: respaldo inalterable con hash de verificación
model td_acta_jc {
  id_acta_jc              Int      @id @default(autoincrement())
  codigo_jc               String   @unique @db.VarChar(60)
  // BLANCA (auditoría tabular) | VERDE (alta seguridad para llenado manual)
  tipo_jc                 String   @db.VarChar(10)
  // Hash SHA-256 del contenido: garantiza que el respaldo digital coincida con el físico
  hashVerificacion_jc     String   @db.VarChar(64)
  id_materia_acta_jc      Int
  id_periodo_acta_jc      Int
  generadaPorUsuarioId_jc Int
  creadoEn_jc             DateTime? @default(now()) @db.Timestamp(6)

  // Relaciones
  materia_jc     td_materia_cjgp           @relation(fields: [id_materia_acta_jc], references: [id_materia_cjgp], onDelete: Cascade)
  periodo_jc     td_periodo_academico_cjgp @relation(fields: [id_periodo_acta_jc], references: [id_periodo_cjgp], onDelete: Cascade)
  generadaPor_jc td_usuario_ahbb           @relation(fields: [generadaPorUsuarioId_jc], references: [id_usuario_ahbb])
}

// ══════════════════════════════════════════════════════════════
// MÓDULO MULTIMEDIA Y VIDEOLLAMADAS (_jf)
// ══════════════════════════════════════════════════════════════

model td_bloques_jf {
  id_bloque_jf       Int      @id @default(autoincrement())
  id_curso_bloque_jf Int
  nombre_jf          String   @db.VarChar(200)
  descripcion_jf     String?  @db.Text
  orden_jf           Int
  creadoEn_jf        DateTime? @default(now()) @db.Timestamp(6)
  actualizadoEn_jf   DateTime? @default(now()) @db.Timestamp(6)

  // Relaciones
  curso_jf           td_curso_ahbb    @relation(fields: [id_curso_bloque_jf], references: [id_curso_ahbb], onDelete: Cascade)
  lecciones_jf       td_lecciones_jf[]
  evaluacion_jf      td_evaluaciones_jf?
}

model td_lecciones_jf {
  id_leccion_jf        Int      @id @default(autoincrement())
  id_bloque_leccion_jf Int
  titulo_jf            String   @db.VarChar(200)
  descripcion_jf       String?  @db.Text
  orden_jf             Int
  tipo_jf              String   @db.VarChar(20) // VIDEO | LECTURA | RECURSO
  urlArchivo_jf        String?  @db.Text
  contenidoTexto_jf    String?  @db.Text
  creadoEn_jf          DateTime? @default(now()) @db.Timestamp(6)
  actualizadoEn_jf     DateTime? @default(now()) @db.Timestamp(6)

  // Relaciones
  bloque_jf            td_bloques_jf    @relation(fields: [id_bloque_leccion_jf], references: [id_bloque_jf], onDelete: Cascade)
  progresos_jf         td_progreso_lecciones_jf[]
}

model td_progreso_lecciones_jf {
  id_progreso_jf             Int      @id @default(autoincrement())
  id_inscripcion_progreso_jf Int
  id_leccion_progreso_jf     Int
  id_usuario_alumno_jf       Int
  completada_jf              Boolean  @default(false)
  porcentajeVisto_jf         Decimal? @db.Decimal(5, 2)
  actualizadoEn_jf           DateTime? @default(now()) @db.Timestamp(6)

  // Relaciones
  inscripcion_jf             td_inscripcion_ahbb @relation(fields: [id_inscripcion_progreso_jf], references: [id_inscripcion_ahbb], onDelete: Cascade)
  leccion_jf                 td_lecciones_jf     @relation(fields: [id_leccion_progreso_jf], references: [id_leccion_jf], onDelete: Cascade)
  alumno_jf                  td_usuario_ahbb     @relation(fields: [id_usuario_alumno_jf], references: [id_usuario_ahbb], onDelete: Cascade)

  @@unique([id_inscripcion_progreso_jf, id_leccion_progreso_jf])
}

model td_evaluaciones_jf {
  id_evaluacion_jf        Int      @id @default(autoincrement())
  id_bloque_evaluacion_jf Int      @unique
  titulo_jf               String   @db.VarChar(200)
  descripcion_jf          String?  @db.Text
  notaMinima_jf           Decimal  @db.Decimal(5, 2)
  intentosMaximos_jf      Int      @default(3)
  preguntasJson_jf        Json
  creadoEn_jf             DateTime? @default(now()) @db.Timestamp(6)
  actualizadoEn_jf        DateTime? @default(now()) @db.Timestamp(6)

  // Relaciones
  bloque_jf               td_bloques_jf @relation(fields: [id_bloque_evaluacion_jf], references: [id_bloque_jf], onDelete: Cascade)
  intentos_jf             td_intento_evaluacion_jf[]
}

model td_intento_evaluacion_jf {
  id_intento_jf             Int      @id @default(autoincrement())
  id_evaluacion_intento_jf  Int
  id_inscripcion_intento_jf Int
  id_usuario_alumno_jf      Int
  notaObtenida_jf           Decimal  @db.Decimal(5, 2)
  aprobado_jf               Boolean  @default(false)
  respuestasAlumnoJson_jf   Json
  fechaIntento_jf           DateTime? @default(now()) @db.Timestamp(6)

  // Relaciones
  evaluacion_jf             td_evaluaciones_jf  @relation(fields: [id_evaluacion_intento_jf], references: [id_evaluacion_jf], onDelete: Cascade)
  inscripcion_jf            td_inscripcion_ahbb @relation(fields: [id_inscripcion_intento_jf], references: [id_inscripcion_ahbb], onDelete: Cascade)
  alumno_jf                 td_usuario_ahbb     @relation(fields: [id_usuario_alumno_jf], references: [id_usuario_ahbb], onDelete: Cascade)
}

model td_salas_videollamadas_jf {
  id_sala_jf           Int      @id @default(autoincrement())
  id_curso_sala_jf     Int
  id_usuario_creador_jf Int
  nombreSala_jf        String   @db.VarChar(100)
  titulo_jf            String   @db.VarChar(200)
  estado_jf            String   @default("PROGRAMADA") @db.VarChar(20)
  fechaProgramada_jf   DateTime @db.Timestamp(6)
  fechaInicioReal_jf   DateTime? @db.Timestamp(6)
  fechaFinReal_jf      DateTime? @db.Timestamp(6)
  duracionSegundos_jf  Int?     @default(0)
  creadoEn_jf          DateTime? @default(now()) @db.Timestamp(6)

  // Relaciones
  curso_jf             td_curso_ahbb   @relation(fields: [id_curso_sala_jf], references: [id_curso_ahbb], onDelete: Cascade)
  creador_jf           td_usuario_ahbb @relation(fields: [id_usuario_creador_jf], references: [id_usuario_ahbb], onDelete: Cascade)
}

model td_auditoria_multimedia_jf {
  id_auditoria_jf      Int      @id @default(autoincrement())
  tabla_jf             String   @db.VarChar(50)
  operacion_jf         String   @db.VarChar(20)
  registro_id_jf       Int
  datos_anteriores_jf  Json?
  datos_nuevos_jf      Json?
  usuario_jf           String?  @db.VarChar(100)
  fecha_jf             DateTime @default(now()) @db.Timestamp(6)
}
